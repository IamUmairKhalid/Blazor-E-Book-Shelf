@inherits LayoutComponentBase

<HeadContent>
    <link rel="stylesheet" href="@Assets["AdminLayout.css"]" />
    <link href="AdminMenu.css" rel="stylesheet" />
</HeadContent>

<div class="page">
    <div class="sidebar">
        <AdminMenu/>
    </div>

    <main>
        <div class="top-row px-4 border-3 shadow-sm p-0" style="font-family: 'Open Sans' , sans-serif; font-weight: 600; color: #555555;">

            <AdminTopBar />
            <ThemeSwitcher />
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>



